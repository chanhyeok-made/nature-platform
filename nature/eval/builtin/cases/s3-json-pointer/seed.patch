+"""Tiny JSON Pointer (RFC 6901) resolver — three edge-case bugs.
+Fix `resolve` so `tests/test_jsonptr.py` passes."""
+
+from __future__ import annotations
+
+from typing import Any
+
+
+def resolve(doc: Any, pointer: str) -> Any:
+    assert pointer.startswith("/"), "pointer must start with /"
+    result = doc
+    for token in pointer[1:].split("/"):
+        token = token.replace("~0", "~").replace("~1", "/")
+        result = result[token]
+    return result
diff --git a/tests/test_jsonptr.py b/tests/test_jsonptr.py
