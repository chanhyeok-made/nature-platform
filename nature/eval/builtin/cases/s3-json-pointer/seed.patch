@@ -0,0 +1,21 @@
+import sys
+from pathlib import Path
+sys.path.insert(0, str(Path(__file__).resolve().parent.parent))
+from jsonptr import resolve  # noqa: E402
+
+
+def test_basic_nested_dict():
+    assert resolve({"foo": {"bar": 1}}, "/foo/bar") == 1
+
+
+def test_empty_pointer_returns_whole_document():
+    doc = {"a": 1}
+    assert resolve(doc, "") == doc
+
+
+def test_array_index_numeric_token():
+    assert resolve([10, 20, 30], "/1") == 20
+
+
+def test_escape_order_tilde_one_before_tilde_zero():
+    assert resolve({"~1": "value"}, "/~01") == "value"
