@@ -0,0 +1,20 @@
+import sys
+from pathlib import Path
+sys.path.insert(0, str(Path(__file__).resolve().parent.parent))
+from mycsv import parse_row  # noqa: E402
+
+
+def test_unquoted_commas_split_normally():
+    assert parse_row("a,b,c") == ["a", "b", "c"]
+
+
+def test_quoted_comma_is_preserved():
+    assert parse_row('"hello, world",foo') == ["hello, world", "foo"]
+
+
+def test_escaped_double_quote_becomes_literal():
+    assert parse_row('"he said ""hi"", then left"') == ['he said "hi", then left']
+
+
+def test_trailing_empty_field_is_preserved():
+    assert parse_row("a,b,") == ["a", "b", ""]
