+"""Tiny CSV parser — three edge-case bugs. Fix `parse_row` so tests pass."""
+
+from __future__ import annotations
+
+
+def parse_row(line: str) -> list[str]:
+    fields = []
+    for chunk in line.split(","):
+        if chunk.startswith('"') and chunk.endswith('"'):
+            chunk = chunk[1:-1]
+        fields.append(chunk)
+    if fields and fields[-1] == "":
+        fields.pop()
+    return fields
diff --git a/tests/test_mycsv.py b/tests/test_mycsv.py
